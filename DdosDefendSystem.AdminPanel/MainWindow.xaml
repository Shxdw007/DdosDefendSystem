<Window x:Class="DdosDefendSystem.AdminPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Security Monitor" Height="600" Width="1000"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#0C0C0C" BorderBrush="#8204A6" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#8204A6" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#C0C0C0">
                <TextBlock Text="■ C:\network_monitor.exe" FontFamily="./Fonts/#Perfect DOS VGA 437" 
                           FontWeight="Bold" Foreground="Black" VerticalAlignment="Center" Margin="10,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="_" Width="30" Background="Transparent" BorderThickness="0" FontWeight="Bold" Foreground="Black" Click="MinimizeButton_Click"/>
                    <Button Content="X" Width="30" Background="Transparent" BorderThickness="0" FontWeight="Bold" Foreground="Black" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TRAFFIC SCANNER &amp; FIREWALL SYSTEM_" 
                           FontFamily="PERFECTDOSVGA437" FontSize="22" Foreground="#00BFFF" Margin="0,0,0,20"/>

                <TabControl Grid.Row="1" Background="Transparent" BorderBrush="#8204A6" BorderThickness="0,1,0,0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" BorderThickness="1,1,1,0" BorderBrush="#333" Background="#111" Margin="2,0,2,5" Padding="15,8">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#8204A6"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#8204A6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontFamily" Value="./Fonts/#Perfect DOS VGA 437"/>
                            <Setter Property="FontSize" Value="14"/>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header=" [ LIVE TRAFFIC ] " FontFamily="PERFECTDOSVGA437">
                        <Grid Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="> Поток входящих сетевых пакетов в реальном времени:" Foreground="#32CD32" FontFamily="PERFECTDOSVGA437" Margin="0,0,0,10"/>

                            <ListView x:Name="LiveTrafficLog" Grid.Row="1" Background="#050505" BorderBrush="#333" Foreground="#00BFFF" FontFamily="PERFECTDOSVGA437" FontSize="13">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="IP Адрес" DisplayMemberBinding="{Binding IpAddress}" Width="150"/>
                                        <GridViewColumn Header="Метод" DisplayMemberBinding="{Binding HttpMethod}" Width="80"/>
                                        <GridViewColumn Header="Эндпоинт" DisplayMemberBinding="{Binding Uri}" Width="250"/>
                                        <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding StatusCode}" Width="80"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </TabItem>

                    <TabItem Header=" [ BLACKLIST CONTROLS ] " FontFamily="PERFECTDOSVGA437">
                        <Grid Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="60"/>
                            </Grid.RowDefinitions>

                            <DataGrid x:Name="BlacklistGrid" Grid.Row="0" AutoGenerateColumns="False" FontFamily="PERFECTDOSVGA437" IsReadOnly="True" 
                                      Background="#050505" RowBackground="#0D0D0D" AlternatingRowBackground="#141414" 
                                      Foreground="White" BorderBrush="#333" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#222"/>
                                        <Setter Property="Foreground" Value="#00BFFF"/>
                                        <Setter Property="FontFamily" Value="PERFECTDOSVGA437"/>
                                        <Setter Property="Padding" Value="5"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="IP Адрес" Binding="{Binding IpAddress}" Width="140"/>
                                    <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                                    <DataGridTextColumn Header="Осталось времени" Binding="{Binding TimeLeftString}" Width="160">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#E02A00"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <Button Content="[ ПЕРМАНЕНТНЫЙ БАН ]" Width="180" Height="35" Background="#F76802" Foreground="White" 
                                        FontFamily="./Fonts/#Perfect DOS VGA 437" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="PermanentBan_Click" Margin="0,0,10,0"/>
                                <Button Content="[ СНЯТЬ БЛОКИРОВКУ ]" Width="180" Height="35" Background="#333" Foreground="White" 
                                        FontFamily="./Fonts/#Perfect DOS VGA 437" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="Unban_Click"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>
</Window>