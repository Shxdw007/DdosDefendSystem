<UserControl x:Class="DdosDefendSystem.AdminPanel.Views.BlacklistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid Grid.Row="0" ItemsSource="{Binding BannedIps}" SelectedItem="{Binding SelectedBan}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="IP Адрес" Binding="{Binding IpAddress}" Width="140"/>
                <DataGridTextColumn Header="Причина" Binding="{Binding Reason}" Width="*"/>
                <DataGridTextColumn Header="Осталось" Binding="{Binding TimeLeftString}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Перманентный бан" Style="{StaticResource PrimaryButton}"
                    Command="{Binding PermanentBanCommand}" Margin="0,0,10,0"/>
            <Button Content="Снять блокировку" Style="{StaticResource SecondaryButton}"
                    Command="{Binding UnbanCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
