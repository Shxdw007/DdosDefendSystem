<UserControl x:Class="DdosDefendSystem.AdminPanel.Views.WhitelistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox Width="200" Text="{Binding NewIpAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
            <Button Content="Добавить" Style="{StaticResource PrimaryButton}" Command="{Binding AddCommand}" Margin="0,0,10,0"/>
            <Button Content="Обновить" Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}"/>
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="IP Адрес" Binding="{Binding IpAddress}" Width="160"/>
                <DataGridTextColumn Header="Добавлен" Binding="{Binding AddedAt}" Width="180"/>
                <DataGridTextColumn Header="Кем" Binding="{Binding AddedBy}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Button Grid.Row="2" Content="Удалить выбранный" Style="{StaticResource SecondaryButton}"
                Command="{Binding DeleteCommand}" HorizontalAlignment="Right" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
