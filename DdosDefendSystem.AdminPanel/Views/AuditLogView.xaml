<UserControl x:Class="DdosDefendSystem.AdminPanel.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Grid.Row="0" Content="Обновить" Style="{StaticResource SecondaryButton}"
                Command="{Binding RefreshCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Entries}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Время" Binding="{Binding Timestamp}" Width="180"/>
                <DataGridTextColumn Header="Пользователь" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="160"/>
                <DataGridTextColumn Header="Детали" Binding="{Binding Details}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
