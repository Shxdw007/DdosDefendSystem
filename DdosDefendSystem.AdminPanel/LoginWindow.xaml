<Window x:Class="DdosDefendSystem.AdminPanel.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Login" Height="500" Width="700"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="#000000" BorderBrush="#8204A6" BorderThickness="2" CornerRadius="0">
        <Border.Effect>
            <DropShadowEffect Color="#8204A6" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#C0C0C0">
                <TextBlock Text="■ C:\system_auth.exe" FontFamily="Consolas" FontWeight="Bold" 
                           Foreground="Black" VerticalAlignment="Center" Margin="10,0"/>
                <Button Content="X" HorizontalAlignment="Right" Width="30" Background="Transparent" 
                        BorderThickness="0" FontWeight="Bold" Click="CloseButton_Click"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="40">
                <TextBlock Text="SCANER TRAFIC" FontFamily="PERFECTDOSVGA437" FontSize="28" FontWeight="Bold" 
                           Foreground="#8204A6" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="-+-  -+-" FontFamily="PERFECTDOSVGA437" FontSize="14" FontWeight="Bold" 
                           Foreground="#8204A6" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="> INITIALIZE_AUTH_SEQUENCE_" FontFamily="PERFECTDOSVGA437" Foreground="#32CD32" Margin="0,0,0,20"/>

                <TextBlock Text="USERNAME:" FontFamily="PERFECTDOSVGA437" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Background="Transparent" Foreground="#00BFFF" FontFamily="Consolas" 
                         FontSize="16" BorderBrush="#555" BorderThickness="0,0,0,1" Margin="0,0,0,20" CaretBrush="#00BFFF"/>

                <TextBlock Text="PASSWORD:" FontFamily="PERFECTDOSVGA437" Foreground="White" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Background="Transparent" Foreground="#00BFFF" FontFamily="Consolas" 
                             FontSize="16" BorderBrush="#555" BorderThickness="0,0,0,1" Margin="0,0,0,30" CaretBrush="#00BFFF"/>

                <TextBlock x:Name="ErrorText" Text="ACCESS DENIED" Foreground="#E02A00" FontFamily="Consolas" 
                           Visibility="Hidden" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Button x:Name="LoginButton" Content="[ LOGIN ]" FontFamily="PERFECTDOSVGA437" FontSize="18" FontWeight="Bold" 
                       Background="#F76802" Foreground="White" BorderThickness="0" Height="40" Cursor="Hand" Click="LoginButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00BFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="\(^.^)/" FontFamily="PERFECTDOSVGA437" FontSize="24" FontWeight="Bold" 
                           Foreground="#32CD32" HorizontalAlignment="Center" Margin="0,40,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>